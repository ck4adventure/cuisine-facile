---
// Reference panel — desktop sidebar only.
// Content is populated at runtime by RecipeView.astro's script.
---

<aside id="ref-panel" class="ref-panel" aria-label="Referenced recipe">
  <div class="ref-panel__label">Referenced Recipes</div>
  <p class="ref-panel__empty">Tap a linked recipe to see it here.</p>
  <div class="ref-card">
    <div class="ref-card__num"></div>
    <div class="ref-card__title"></div>
    <div class="ref-card__body"></div>
  </div>
</aside>
