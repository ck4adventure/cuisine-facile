---
import type { NavLink } from '../lib/nav';

interface Props {
  prev: NavLink;
  next: NavLink;
}
const { prev, next } = Astro.props;
---

<nav class="recipe-nav" aria-label="Recipe navigation">
  {prev ? (
    <a href={prev.href} class="recipe-nav__btn recipe-nav__btn--prev">
      <span class="recipe-nav__dir">{prev.dirLabel ?? '← Previous'}</span>
      <span class="recipe-nav__title lang-fr">{prev.titleFr}</span>
      {prev.titleEn && <span class="recipe-nav__title lang-en">{prev.titleEn}</span>}
      {prev.num && <span class="recipe-nav__num">{prev.num}</span>}
    </a>
  ) : (
    <span></span>
  )}

  {next ? (
    <a href={next.href} class="recipe-nav__btn recipe-nav__btn--next">
      <span class="recipe-nav__dir">{next.dirLabel ?? 'Next →'}</span>
      <span class="recipe-nav__title lang-fr">{next.titleFr}</span>
      {next.titleEn && <span class="recipe-nav__title lang-en">{next.titleEn}</span>}
      {next.num && <span class="recipe-nav__num">{next.num}</span>}
    </a>
  ) : (
    <span></span>
  )}
</nav>
